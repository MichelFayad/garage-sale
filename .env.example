# ─── Database ───────────────────────────────────────────────
# Postgres connection string (Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/garage_sale?schema=public"

# ─── Auth (Auth.js) ─────────────────────────────────────────
AUTH_SECRET="generate-with: npx auth secret"
AUTH_URL="http://localhost:3000"

# JWT for mobile/API bearer auth
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="900"          # seconds (15m)
JWT_REFRESH_TTL="2592000"     # seconds (30d)

# ─── OAuth providers ────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Apple Sign In (web): the client secret is a signed JWT built from these pieces.
APPLE_CLIENT_ID=""            # Services ID
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""          # PKCS#8 PEM (-----BEGIN PRIVATE KEY----- …)
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# ─── Stripe ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ─── Push notifications (Firebase Cloud Messaging) ──────────
# Service-account credentials for the Firebase project backing FCM. Leave
# unset in dev — sendPush swallows the resulting error and silently no-ops,
# same as an unset RESEND_API_KEY degrades email.
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""       # PKCS#8 PEM (-----BEGIN PRIVATE KEY----- …)

# ─── Email (transactional) ──────────────────────────────────
EMAIL_PROVIDER="resend"       # resend | ses
RESEND_API_KEY=""
EMAIL_FROM="Garage Sale <no-reply@garagesale.example>"

# ─── Cron (untrusted-flag sweep) ────────────────────────────
# Scheduler sends `Authorization: Bearer <CRON_SECRET>` to /api/cron/untrusted
CRON_SECRET=""

# ─── App URLs ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# ─── Analytics (privacy-friendly, optional) ─────────────────
# Cookieless Plausible-compatible analytics. Leave the domain blank to disable
# (the script won't load). NEXT_PUBLIC_ANALYTICS_SRC overrides the script host
# for a self-hosted instance.
NEXT_PUBLIC_ANALYTICS_DOMAIN=""
NEXT_PUBLIC_ANALYTICS_SRC=""

# ─── Mobile (Flutter) ───────────────────────────────────────
# The Flutter app (apps/mobile) reads config via --dart-define at build/run
# time, NOT from this .env file. Pass these when launching:
#   flutter run \
#     --dart-define=API_BASE_URL=http://10.0.2.2:3000/api \  # 10.0.2.2 = host from Android emulator
#     --dart-define=STRIPE_PUBLISHABLE_KEY=pk_test_...
# FCM needs a real Firebase project (google-services.json / GoogleService-Info.plist
# from `flutterfire configure`), provisioned separately — see CLAUDE.md.
# OAuth (Google/Apple/Facebook) was not ported to Flutter yet (deferred).
