# ─── Database ───────────────────────────────────────────────
# Postgres connection string (Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/garage_sale?schema=public"

# ─── Auth (Auth.js) ─────────────────────────────────────────
AUTH_SECRET="generate-with: npx auth secret"
AUTH_URL="http://localhost:3000"

# JWT for mobile/API bearer auth
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="900"          # seconds (15m)
JWT_REFRESH_TTL="2592000"     # seconds (30d)

# ─── OAuth providers ────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Apple Sign In (web): the client secret is a signed JWT built from these pieces.
APPLE_CLIENT_ID=""            # Services ID
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""          # PKCS#8 PEM (-----BEGIN PRIVATE KEY----- …)
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# ─── Stripe ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ─── Email (transactional) ──────────────────────────────────
EMAIL_PROVIDER="resend"       # resend | ses
RESEND_API_KEY=""
EMAIL_FROM="Garage Sale <no-reply@garagesale.example>"

# ─── App URLs ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# ─── Mobile (Expo) ──────────────────────────────────────────
EXPO_PUBLIC_API_URL="http://localhost:3000/api"
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Mobile OAuth (expo-auth-session). Apple uses the native module (no client id).
EXPO_PUBLIC_GOOGLE_CLIENT_ID=""          # web client id (for id_token)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=""
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=""
EXPO_PUBLIC_FACEBOOK_CLIENT_ID=""
