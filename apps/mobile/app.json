{
  "expo": {
    "name": "Garage Sale",
    "slug": "garage-sale",
    "version": "0.0.0",
    "orientation": "portrait",
    "scheme": "garagesale",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.garagesale.app"
    },
    "android": {
      "package": "com.garagesale.app"
    },
    "plugins": [
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.garagesale.app",
          "enableGooglePay": false
        }
      ]
    ]
  }
}
